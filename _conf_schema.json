{
  "default_r18": {
    "description": "默认 R18 等级（0=全年龄, 1=R18, 2=混合）",
    "type": "int",
    "default": 0
  },
  "default_num": {
    "description": "默认获取图片数量（1-20）",
    "type": "int",
    "default": 1
  },
  "default_size": {
    "description": "默认图片尺寸（original/regular/small/thumb/mini）",
    "type": "string",
    "default": "regular"
  },
  "image_proxy": {
    "description": "图片代理域名",
    "type": "string",
    "default": "pixiv.bileizhen.top"
  },
  "exclude_ai": {
    "description": "是否默认排除 AI 生成的作品",
    "type": "bool",
    "default": false
  },
  "request_timeout": {
    "description": "API 请求超时时间（秒）",
    "type": "int",
    "default": 15
  },
  "femboy_api_key": {
    "description": "男娘图片 API 密钥 (x-api-key)，留空则禁用 /femboy 命令",
    "type": "string",
    "default": ""
  },
  "dglab": {
    "description": "DG-LAB Socket V2 集成配置（JSON格式: {\"server_url\":\"\", \"heartbeat_interval\":60, \"auto_connect\":false}）",
    "type": "string",
    "default": ""
  }
}
