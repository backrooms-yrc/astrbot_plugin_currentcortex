{
  "description": "Pixiv 插件配置",
  "type": "object",
  "properties": {
    "api_base_url": {
      "description": "API 基础 URL，留空则使用默认值",
      "type": "string",
      "default": ""
    },
    "tag_blacklist": {
      "description": "标签黑名单，包含这些标签的作品将被过滤",
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "dglab": {
      "description": "DG-LAB Socket V2 集成配置",
      "type": "object",
      "properties": {
        "server_url": {
          "description": "DG-LAB 中转服务器地址 (例如 ws://host:port 或 wss://host:port，不要带 clientId 路径)",
          "type": "string",
          "default": ""
        },
        "heartbeat_interval": {
          "description": "心跳间隔(秒)",
          "type": "number",
          "default": 60
        },
        "auto_connect": {
          "description": "启动时自动连接",
          "type": "boolean",
          "default": false
        }
      },
      "default": {}
    }
  }
}
