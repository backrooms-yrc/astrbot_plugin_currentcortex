# ============================================
# Python 编译与缓存
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ============================================
# 虚拟环境
# ============================================
env/
venv/
.venv/
ENV/

# ============================================
# 打包与分发
# ============================================
*.egg-info/
dist/
build/
eggs/
*.egg

# ============================================
# IDE 与编辑器
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ============================================
# 操作系统生成文件
# ============================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ============================================
# 环境变量文件（可能包含 API 密钥、数据库凭证等）
# ============================================
.env
.env.*
!.env.example

# ============================================
# 运行时数据目录（包含用户 PII、会话令牌、密码哈希等敏感信息）
# ============================================
data/

# ============================================
# 密钥与证书文件
# ============================================
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
*.cert
*.p7b
*.p7c

# ============================================
# SSH 相关文件
# ============================================
id_rsa
id_dsa
id_ecdsa
id_ed25519
known_hosts
authorized_keys
.ssh/

# ============================================
# 数据库文件
# ============================================
*.db
*.sqlite
*.sqlite3
*.sql

# ============================================
# 日志文件
# ============================================
*.log
logs/

# ============================================
# 临时文件
# ============================================
*.tmp
*.bak
*.temp
temp_doc.html

# ============================================
# 误创建的空文件（数字/带引号的文件名）
# ============================================
/120
/148
/185
/185'
/189'

# ============================================
# 进程 ID 文件
# ============================================
*.pid

# ============================================
# 开发辅助文件（包含 exec() 动态代码执行，不应部署）
# ============================================
_dev_webui.py

# ============================================
# 测试文件（包含硬编码内网 IP 等信息）
# ============================================
test_*.py
